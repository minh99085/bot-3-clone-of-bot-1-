//@version=6
// =====================================================================================
// Hermes Bar-Close 5m — OHLC heartbeat for BTCUSD / ETHUSD (4-chart setup)
// =====================================================================================
// Charts (2 of 4): BINANCE:BTCUSDT + BINANCE:ETHUSDT · 5m
// Pair with Hermes RSI Divergence 5m Accurate on the same charts (overlay pane).
//
// Alert: Condition = Any alert() function call
//        (no "Once per bar close" UI — frequency is alert.freq_once_per_bar_close in Pine)
// Webhook: http://144.202.122.120/webhooks/tradingview · Message: {{message}}
// =====================================================================================
indicator(title="Hermes BarClose 5m", shorttitle="Hermes5m", overlay=true,
     max_labels_count=50)

secretInput   = input.string("PASTE_YOUR_HERMES_WEBHOOK_SECRET", "Hermes webhook secret")
webhookUrl    = input.string("http://144.202.122.120/webhooks/tradingview", "Hermes webhook URL (paste into Alert → Webhook URL)")
botName       = input.string("hermes", "Bot name")
indicatorName = input.string("Hermes BarClose 5m", "Indicator name")
eventSuffix   = input.string("bot1", "Event id suffix (bot1)")

jsonNum(x) => na(x) ? "null" : str.tostring(x)

bodyAbs = math.abs(close - open)
barRange = math.max(high - low, syminfo.mintick)
bodyRatio = barRange > 0 ? math.min(1.0, bodyAbs / barRange) : 0.0
strength = 0.45 + 0.55 * bodyRatio
bodyPct = open != 0.0 ? 100.0 * (close - open) / open : 0.0

direction = close >= open ? "UP" : "DOWN"
signalLevel = close >= open ? "BAR_BULL" : "BAR_BEAR"

var int streak = 0
if barstate.isconfirmed
    prevDir = close[1] >= open[1] ? 1 : -1
    curDir = close >= open ? 1 : -1
    streak := curDir == prevDir ? streak + 1 : 1

f_hermes_msg() =>
    eventId = syminfo.ticker + "-" + timeframe.period + "-" + str.tostring(time) + "-" + signalLevel + "-bar5m-" + eventSuffix
    msg = "{"
    msg := msg + "\"secret\":\""          + secretInput + "\","
    msg := msg + "\"bot_name\":\""         + botName + "\","
    msg := msg + "\"source\":\"tradingview\","
    msg := msg + "\"symbol\":\""           + syminfo.ticker + "\","
    msg := msg + "\"timeframe\":\""        + timeframe.period + "\","
    msg := msg + "\"direction\":\""        + direction + "\","
    msg := msg + "\"signal_level\":\""     + signalLevel + "\","
    msg := msg + "\"strength\":"           + jsonNum(strength) + ","
    msg := msg + "\"indicator_name\":\""   + indicatorName + "\","
    msg := msg + "\"signal_kind\":\"bar_close_5m\","
    msg := msg + "\"event_id\":\""         + eventId + "\","
    msg := msg + "\"bar_time\":\""         + str.tostring(time_close) + "\","
    msg := msg + "\"price\":"              + jsonNum(close) + ","
    msg := msg + "\"open\":"               + jsonNum(open) + ","
    msg := msg + "\"high\":"               + jsonNum(high) + ","
    msg := msg + "\"low\":"                + jsonNum(low) + ","
    msg := msg + "\"close\":"              + jsonNum(close) + ","
    msg := msg + "\"body_pct\":"           + jsonNum(bodyPct) + ","
    msg := msg + "\"body_ratio\":"         + jsonNum(bodyRatio) + ","
    msg := msg + "\"streak\":"             + jsonNum(streak) + ","
    msg := msg + "\"bar_confirmed\":true,"
    msg := msg + "\"non_repainting\":true,"
    msg := msg + "\"composite_version\":\"hermes_bar_close_5m_v1\","
    msg := msg + "\"observe_only\":true"
    msg := msg + "}"
    msg

plotshape(barstate.isconfirmed and close >= open, title="Bull bar", style=shape.triangleup,
     location=location.belowbar, color=color.new(color.teal, 20), size=size.tiny)
plotshape(barstate.isconfirmed and close < open, title="Bear bar", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.red, 20), size=size.tiny)

alertcondition(barstate.isconfirmed, title="Hermes 5m bar close",
     message="Use Any alert() function call — not this alertcondition")

if barstate.isconfirmed
    alert(f_hermes_msg(), alert.freq_once_per_bar_close)
