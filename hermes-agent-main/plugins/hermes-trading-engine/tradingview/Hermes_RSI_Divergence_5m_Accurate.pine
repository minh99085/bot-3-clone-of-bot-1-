//@version=6
// =====================================================================================
// Hermes RSI Divergence 5m — regular bull/bear + JSON webhook (confirm/fade overlay)
// =====================================================================================
// Core pivot/divergence math matches TradingView's standard RSI Divergence indicator.
// "Accurate" extra gates (zone + min RSI delta + min price %) are OPTIONAL per profile.
//
// Charts (2 of 4): BINANCE:BTCUSDT + BINANCE:ETHUSDT · 5m
// Pair with Hermes BarClose 5m on the same chart layout (separate pane).
//
// Alert (CRITICAL): create alert while THIS indicator is selected →
//   Condition = Any alert() function call
//   Message = {{message}}
//   Webhook = http://144.202.122.120/webhooks/tradingview
// =====================================================================================
indicator(title="Hermes RSI Divergence 5m Accurate", shorttitle="HermesRSI5m",
     format=format.price)

secretInput   = input.string("PASTE_YOUR_HERMES_WEBHOOK_SECRET", "Hermes webhook secret")
webhookUrl    = input.string("http://144.202.122.120/webhooks/tradingview", "Hermes webhook URL (paste into Alert → Webhook URL)")
botName       = input.string("hermes", "Bot name")
indicatorName = input.string("Hermes RSI Divergence 5m Accurate", "Indicator name")

// standard = TV base RSI div (fires occasionally). balanced = light extra gates (default).
// strict   = original sparse tuning (may go days without a signal on 5m).
accuracyMode = input.string("balanced", "Accuracy profile",
     options=["standard", "balanced", "strict"],
     tooltip="standard matches base RSI div. strict adds tight zone/delta gates (very sparse).")

len = input.int(title="RSI Period", minval=1, defval=14)
src = input(title="RSI Source", defval=close)

jsonNum(x) => na(x) ? "null" : str.tostring(x)

// Effective params per profile (manual inputs ignored unless profile = standard)
effLbR = accuracyMode == "strict" ? 7 : 5
effLbL = accuracyMode == "strict" ? 7 : 5
effRangeUpper = accuracyMode == "strict" ? 36 : 60
effRangeLower = accuracyMode == "strict" ? 8 : 5
effBullMax = accuracyMode == "strict" ? 38.0 : accuracyMode == "balanced" ? 45.0 : 55.0
effBearMin = accuracyMode == "strict" ? 62.0 : accuracyMode == "balanced" ? 55.0 : 45.0
effMinRsiDelta = accuracyMode == "strict" ? 4.0 : accuracyMode == "balanced" ? 2.0 : 0.0
effMinPricePct = accuracyMode == "strict" ? 0.12 : accuracyMode == "balanced" ? 0.05 : 0.0
effUseZone = accuracyMode != "standard"
effUseDelta = accuracyMode != "standard"

osc = ta.rsi(src, len)
plot(osc, title="RSI", linewidth=2, color=#2962FF)
hline(50, title="Middle Line", color=#787B86, linestyle=hline.style_dotted)
obLevel = hline(70, title="Overbought", color=#787B86, linestyle=hline.style_dotted)
osLevel = hline(30, title="Oversold", color=#787B86, linestyle=hline.style_dotted)
fill(obLevel, osLevel, title="Background", color=color.rgb(33, 150, 243, 90))

plFound = not na(ta.pivotlow(osc, effLbL, effLbR))
phFound = not na(ta.pivothigh(osc, effLbL, effLbR))

_inRange(cond) =>
    bars = ta.barssince(cond == true)
    effRangeLower <= bars and bars <= effRangeUpper

inRangePl = _inRange(plFound[1])
inRangePh = _inRange(phFound[1])

prevOscPl = ta.valuewhen(plFound, osc[effLbR], 1)
prevLowPl = ta.valuewhen(plFound, low[effLbR], 1)
prevOscPh = ta.valuewhen(phFound, osc[effLbR], 1)
prevHighPh = ta.valuewhen(phFound, high[effLbR], 1)

curOscPl = osc[effLbR]
curLowPl = low[effLbR]
curOscPh = osc[effLbR]
curHighPh = high[effLbR]

hasPrevPl = not na(prevOscPl) and not na(prevLowPl)
hasPrevPh = not na(prevOscPh) and not na(prevHighPh)

rsiDeltaBull = curOscPl - prevOscPl
rsiDeltaBear = prevOscPh - curOscPh
pricePctBull = prevLowPl != 0.0 ? 100.0 * math.abs(curLowPl - prevLowPl) / prevLowPl : 0.0
pricePctBear = prevHighPh != 0.0 ? 100.0 * math.abs(curHighPh - prevHighPh) / prevHighPh : 0.0

// Regular bull: price LL + RSI HL (+ optional zone/delta gates)
oscHL = hasPrevPl and curOscPl > prevOscPl and inRangePl
priceLL = hasPrevPl and curLowPl < prevLowPl
bullZoneOk = not effUseZone or curOscPl <= effBullMax
bullDeltaOk = not effUseDelta or (rsiDeltaBull >= effMinRsiDelta and pricePctBull >= effMinPricePct)
bullCore = plFound and priceLL and oscHL
bullCondAlert = bullCore and bullZoneOk and bullDeltaOk

// Regular bear: price HH + RSI LH (+ optional zone/delta gates)
oscLH = hasPrevPh and curOscPh < prevOscPh and inRangePh
priceHH = hasPrevPh and curHighPh > prevHighPh
bearZoneOk = not effUseZone or curOscPh >= effBearMin
bearDeltaOk = not effUseDelta or (rsiDeltaBear >= effMinRsiDelta and pricePctBear >= effMinPricePct)
bearCore = phFound and priceHH and oscLH
bearCondAlert = bearCore and bearZoneOk and bearDeltaOk

f_strength_bull() =>
    zoneScore = math.max(0.0, math.min(1.0, (effBullMax - curOscPl) / math.max(1.0, effBullMax - 20.0)))
    deltaScore = math.max(0.0, math.min(1.0, rsiDeltaBull / 12.0))
    0.72 + 0.18 * zoneScore + 0.08 * deltaScore

f_strength_bear() =>
    zoneScore = math.max(0.0, math.min(1.0, (curOscPh - effBearMin) / math.max(1.0, 80.0 - effBearMin)))
    deltaScore = math.max(0.0, math.min(1.0, rsiDeltaBear / 12.0))
    0.72 + 0.18 * zoneScore + 0.08 * deltaScore

f_hermes_msg(string direction, string signalLevel, string divKind, float rsiVal, float strength, float rsiDelta, float pricePct) =>
    eventId = syminfo.ticker + "-" + timeframe.period + "-" + str.tostring(time) + "-" + signalLevel + "-rsidiv5m-bot1"
    msg = "{"
    msg := msg + "\"secret\":\""          + secretInput + "\","
    msg := msg + "\"bot_name\":\""         + botName + "\","
    msg := msg + "\"source\":\"tradingview\","
    msg := msg + "\"symbol\":\""           + syminfo.ticker + "\","
    msg := msg + "\"timeframe\":\""        + timeframe.period + "\","
    msg := msg + "\"direction\":\""        + direction + "\","
    msg := msg + "\"signal_level\":\""     + signalLevel + "\","
    msg := msg + "\"strength\":"           + jsonNum(strength) + ","
    msg := msg + "\"indicator_name\":\""   + indicatorName + "\","
    msg := msg + "\"signal_kind\":\"rsi_divergence\","
    msg := msg + "\"divergence_kind\":\""  + divKind + "\","
    msg := msg + "\"event_id\":\""         + eventId + "\","
    msg := msg + "\"bar_time\":\""         + str.tostring(time_close) + "\","
    msg := msg + "\"price\":"              + jsonNum(close) + ","
    msg := msg + "\"rsi\":"                + jsonNum(rsiVal) + ","
    msg := msg + "\"rsi_delta\":"          + jsonNum(rsiDelta) + ","
    msg := msg + "\"price_delta_pct\":"    + jsonNum(pricePct) + ","
    msg := msg + "\"accuracy_mode\":\""    + accuracyMode + "\","
    msg := msg + "\"composite_version\":\"rsi_div_5m_accurate_v2\","
    msg := msg + "\"observe_only\":true"
    msg := msg + "}"
    msg

plot(plFound ? osc[effLbR] : na, offset=-effLbR, title="Regular Bullish",
     linewidth=2, color=(bullCondAlert ? color.green : color.new(color.green, 70)),
     display=display.pane)
plotshape(bullCondAlert ? osc[effLbR] : na, offset=-effLbR, title="Bull Label", text=" Bull ",
     style=shape.labelup, location=location.absolute, color=color.green, textcolor=color.white)

plot(phFound ? osc[effLbR] : na, offset=-effLbR, title="Regular Bearish",
     linewidth=2, color=(bearCondAlert ? color.red : color.new(color.red, 70)),
     display=display.pane)
plotshape(bearCondAlert ? osc[effLbR] : na, offset=-effLbR, title="Bear Label", text=" Bear ",
     style=shape.labeldown, location=location.absolute, color=color.red, textcolor=color.white)

showNearMiss = input.bool(false, "Plot near-miss (div ok, zone/delta blocked)")
plotshape(showNearMiss and bullCore and not bullCondAlert ? osc[effLbR] : na, offset=-effLbR,
     title="Bull near-miss", text=" b? ", style=shape.circle, location=location.absolute,
     color=color.new(color.yellow, 30), textcolor=color.white, size=size.tiny)
plotshape(showNearMiss and bearCore and not bearCondAlert ? osc[effLbR] : na, offset=-effLbR,
     title="Bear near-miss", text=" b? ", style=shape.circle, location=location.absolute,
     color=color.new(color.orange, 30), textcolor=color.white, size=size.tiny)

alertcondition(bullCondAlert, title="Hermes Accurate Bull Div", message="Use Any alert() function call")
alertcondition(bearCondAlert, title="Hermes Accurate Bear Div", message="Use Any alert() function call")

if barstate.isconfirmed and bullCondAlert
    alert(f_hermes_msg("UP", "REGULAR_BULL_DIV", "regular_bullish", curOscPl, f_strength_bull(), rsiDeltaBull, pricePctBull), alert.freq_once_per_bar_close)
if barstate.isconfirmed and bearCondAlert
    alert(f_hermes_msg("DOWN", "REGULAR_BEAR_DIV", "regular_bearish", curOscPh, f_strength_bear(), rsiDeltaBear, pricePctBear), alert.freq_once_per_bar_close)
