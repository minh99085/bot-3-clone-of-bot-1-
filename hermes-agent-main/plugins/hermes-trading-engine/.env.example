# Hermes Agent / Polymarket paper-training — .env TEMPLATE (committed, no secrets).
#
# SETUP: copy this file to `.env` (or `.env.local`) and add your real keys there.
#   cp .env.example .env   # then set XAI_API_KEY=...your-key...
#
# Your `.env` / `.env.env` / `.env.local` are GITIGNORED and NOT tracked, so your
# local xAI/Grok key persists across `git pull` and is never overwritten or
# committed. Only this `.env.example` template is tracked. The engine loads keys
# from `.env` (preferred) then `.env.env` then `.env.local` via engine/env_loader.py.
#
# Safe default: paper training only. Live trading remains disabled.
# Add your real XAI_API_KEY locally before running if Grok/xAI reasoning is required.

# ---------------------------------------------------------------------------
# Global safety
# ---------------------------------------------------------------------------
LIVE_TRADING_ENABLED=0
POLYMARKET_LIVE_ENABLED=0
POLYMARKET_LIVE_TRADING_ENABLED=0
POLYMARKET_AUTOTRADE_ENABLED=0
BTC_AUTOTRADE_ENABLED=0

PAPER_TRADING_ENABLED=1
POLYMARKET_PAPER_TRADING_ENABLED=1
POLYMARKET_PAPER_TRAINING_ENABLED=1
PAPER_TRAINING_ENABLED=1

# ---------------------------------------------------------------------------
# BTC pulse: paper-only learning
# ---------------------------------------------------------------------------
BTC_PULSE_ENABLED=1
BTC_PULSE_PAPER_ONLY=1
BTC_PULSE_ISOLATED_LEARNING=1
BTC_PULSE_LIVE_ENABLED=0
BTC_PULSE_REQUIRE_CHAINLINK=1
BTC_PULSE_MAX_DAILY_PAPER_LOSS=300

# Existing HTE flag contradicted BTC_PULSE_ENABLED in uploaded file.
# Keep this enabled for paper training while live/autotrade remains disabled.
HTE_BTC_PULSE_PAPER_ENABLED=1

# ---------------------------------------------------------------------------
# Closed-loop learning / feedback flywheel
# ---------------------------------------------------------------------------
CLOSED_LOOP_LEARNING_ENABLED=1
POLYMARKET_CLOSED_LOOP_LEARNING_ENABLED=1
TRAINING_DECISION_RECORDS_ENABLED=1
NO_TRADE_LABELING_ENABLED=1
SHADOW_DECISION_LOGGING_ENABLED=1
SHADOW_LEARNING_ENABLED=1
LEARNING_STATE_PERSIST_ENABLED=1
PENDING_LABEL_STORE_ENABLED=1
COMPLETED_LABEL_STORE_ENABLED=1

FEEDBACK_ACCELERATOR_ENABLED=1
FEEDBACK_ACCELERATOR_TARGET_MULTIPLIER=50
POLYMARKET_FEEDBACK_ACCELERATOR_ENABLED=1

# ---------------------------------------------------------------------------
# Active learning: allow shadow/no-trade learning, but only realistic tiny trades
# ---------------------------------------------------------------------------
ACTIVE_LEARNING_ENABLED=1
POLYMARKET_ACTIVE_LEARNING_ENABLED=1
POLYMARKET_RANDOM_EXPLORATION_ENABLED=0

EXPLORATION_ENABLED=1
EXPLORATION_TINY_SIZE_ENABLED=1
EXPLORATION_COUNTS_FOR_READINESS=0
POLYMARKET_EXPLORATION_COUNT_TOWARD_READINESS=0

POLYMARKET_ACTIVE_LEARNING_ALLOW_SHADOW_WITHOUT_FILL=1
POLYMARKET_ACTIVE_LEARNING_REQUIRE_REALISTIC_FILL_FOR_TRADE=1
POLYMARKET_ACTIVE_LEARNING_SHADOW_SAMPLES_PER_TICK=50
POLYMARKET_ACTIVE_LEARNING_NEAR_MISS_SAMPLES_PER_TICK=50
POLYMARKET_ACTIVE_LEARNING_NO_TRADE_LABELS_PER_TICK=100
POLYMARKET_ACTIVE_LEARNING_TINY_TRADES_PER_TICK=2

POLYMARKET_EXPLORATION_MAX_TRADES_PER_TICK=2
POLYMARKET_EXPLORATION_MAX_OPEN_TRADES=10
POLYMARKET_EXPLORATION_MAX_CAPITAL_PER_TICK=20
POLYMARKET_EXPLORATION_MAX_POSITION_SIZE=5
POLYMARKET_EXPLORATION_MAX_EXPECTED_LOSS_USD=0.25
POLYMARKET_EXPLORATION_MIN_DEPTH_AT_PRICE=25
POLYMARKET_EXPLORATION_MAX_SPREAD=0.08
POLYMARKET_EXPLORATION_MAX_BOOK_AGE_SEC=20
POLYMARKET_EXPLORATION_MAX_AMBIGUITY_SCORE=0.45
POLYMARKET_EXPLORATION_REQUIRE_PROFITABILITY_ANNOTATION=1
POLYMARKET_EXPLORATION_REQUIRE_REALISTIC_FILL=1
POLYMARKET_EXPLORATION_MAX_PER_EVENT=1
POLYMARKET_EXPLORATION_MAX_PER_CLUSTER=1

# ---------------------------------------------------------------------------
# Strict paper execution realism
# ---------------------------------------------------------------------------
PAPER_ALLOW_PM_REFERENCE_PRICE_FILLS=0
POLYMARKET_REQUIRE_EXECUTABLE_ASK=1
POLYMARKET_REJECT_STALE_BOOK=1
POLYMARKET_REJECT_MISSING_ASK=1
POLYMARKET_REJECT_OFFLINE_STUB_FILLS=1

POLYMARKET_MIN_DEPTH_AT_PRICE=25
POLYMARKET_MAX_SPREAD=0.08
POLYMARKET_MAX_AMBIGUITY_SCORE=0.45
POLYMARKET_MAX_BOOK_AGE_SEC=20

# These audit fields must be emitted non-null by runtime/report code.
POLYMARKET_FILL_REALISM_METRICS_ENABLED=1
POLYMARKET_AFTER_COST_METRICS_ENABLED=1
POLYMARKET_REQUIRE_NON_NULL_AUDIT_METRICS=1

# ---------------------------------------------------------------------------
# ABCAS / Bregman primary strategy
# ---------------------------------------------------------------------------
POLYMARKET_BREGMAN_ENABLED=1
POLYMARKET_ABCAS_ENABLED=1
POLYMARKET_BREGMAN_FULL_CATALOG_ENABLED=1
POLYMARKET_BREGMAN_PRIORITY_ENABLED=1
POLYMARKET_BREGMAN_PROFITABILITY_FIRST=1
POLYMARKET_BREGMAN_REQUIRE_EXECUTABLE_ALL_LEGS=1
POLYMARKET_BREGMAN_ALLOW_REFERENCE_FILLS=0
POLYMARKET_BREGMAN_BLOCK_DUPLICATE_BUNDLES=1
POLYMARKET_BREGMAN_BLOCK_OVERLAPPING_BUNDLES=1

POLYMARKET_BREGMAN_RESERVE_OPEN_SLOTS=3
POLYMARKET_BREGMAN_RESERVE_CAPITAL_USD=100
POLYMARKET_BREGMAN_MAX_BUNDLES_PER_TICK=3
POLYMARKET_BREGMAN_MAX_OPEN_BUNDLES=10
POLYMARKET_BREGMAN_MAX_CAPITAL_PER_TICK=100
POLYMARKET_BREGMAN_MAX_OPEN_CAPITAL_USD=300
POLYMARKET_BREGMAN_MIN_PROFIT_USD=0.02
POLYMARKET_BREGMAN_MIN_ROI=0.002
POLYMARKET_BREGMAN_MIN_AFTER_COST_PROFIT_USD=0.02
POLYMARKET_BREGMAN_MIN_AFTER_COST_ROI=0.002
POLYMARKET_BREGMAN_MAX_SPREAD=0.08
POLYMARKET_BREGMAN_MIN_DEPTH_AT_PRICE=25
POLYMARKET_BREGMAN_MAX_BOOK_AGE_SEC=20
POLYMARKET_BREGMAN_MAX_AMBIGUITY_SCORE=0.45
POLYMARKET_BREGMAN_MAX_OPEN_PER_EVENT=1
POLYMARKET_BREGMAN_MAX_CLUSTER_EXPOSURE_USD=100

POLYMARKET_DIRECTIONAL_CAN_USE_UNUSED_BREGMAN_SLOTS=1
POLYMARKET_DIRECTIONAL_CAN_USE_UNUSED_BREGMAN_CAPITAL=1
POLYMARKET_BLOCK_DIRECTIONAL_ON_BREGMAN_MARKETS=1
POLYMARKET_BLOCK_DIRECTIONAL_ON_BREGMAN_EVENTS=1
POLYMARKET_BLOCK_EXPLORATION_ON_BREGMAN_MARKETS=1
POLYMARKET_BLOCK_EXPLORATION_ON_BREGMAN_EVENTS=1

# ---------------------------------------------------------------------------
# Profitability-first ranking
# ---------------------------------------------------------------------------
POLYMARKET_PROFITABILITY_FIRST=1
POLYMARKET_REQUIRE_PROFITABILITY_ANNOTATION=1
POLYMARKET_MIN_AFTER_COST_EDGE=0.01
POLYMARKET_MIN_AFTER_COST_ROI=0.002
POLYMARKET_MIN_EXPECTED_VALUE_USD=0.01
POLYMARKET_PROFITABILITY_SORT_WEIGHT=1.0
POLYMARKET_MODEL_SCORE_SORT_WEIGHT=0.35
POLYMARKET_LIQUIDITY_SORT_WEIGHT=0.25
POLYMARKET_FRESHNESS_SORT_WEIGHT=0.25
POLYMARKET_AMBIGUITY_PENALTY_WEIGHT=0.50
POLYMARKET_EXECUTION_DRAG_PENALTY_WEIGHT=1.00

# ---------------------------------------------------------------------------
# Correlation / cluster risk gate
# ---------------------------------------------------------------------------
POLYMARKET_CORRELATION_GATE_ENABLED=1
POLYMARKET_REQUIRE_CLUSTER_METADATA=1
POLYMARKET_UNKNOWN_CLUSTER_POLICY=shadow
POLYMARKET_CORRELATION_ALLOW_SIZE_CAP=1

POLYMARKET_MAX_OPEN_PER_MARKET=1
POLYMARKET_MAX_OPEN_PER_EVENT=1
POLYMARKET_MAX_OPEN_PER_CLUSTER=1
POLYMARKET_MAX_CLUSTER_EXPOSURE_USD=25
POLYMARKET_MAX_EVENT_EXPOSURE_USD=25
POLYMARKET_MAX_CORRELATION_GROUP_EXPOSURE_USD=50
POLYMARKET_BLOCK_DUPLICATE_MARKET=1
POLYMARKET_BLOCK_DUPLICATE_EVENT=1
POLYMARKET_BLOCK_DUPLICATE_CLUSTER=1

# ---------------------------------------------------------------------------
# News / Grok evidence path
# ---------------------------------------------------------------------------
NEWS_SCANNER_ENABLED=1
NEWS_PROVIDER_MODE=live_read_only
POLYMARKET_NEWS_SCANNER_ENABLED=1
POLYMARKET_GROK_EVIDENCE_METRICS_ENABLED=1

# Bounded, advisory-ONLY xAI/Grok proof call during paper training. Proves the
# Grok brain is live (research only — it NEVER trades, sizes, or bypasses a gate).
GROK_PROOF_CALL_ENABLED=1
GROK_PROOF_CALL_MAX_PER_RUN=1
GROK_PROOF_CALL_MIN_INTERVAL_SECONDS=900
# Bounded Grok ADVISORY scheduler (research-only): multiple low-frequency advisory
# calls per run on high-value targets (top Bregman near-misses / news-linked /
# high-liquidity). Never executes, sizes, or bypasses a gate.
GROK_ADVISORY_ENABLED=1
GROK_ADVISORY_MAX_CALLS_PER_HOUR=4
GROK_ADVISORY_MIN_INTERVAL_SECONDS=900
GROK_ADVISORY_REQUIRE_NEWS=1
# Bregman near-miss diagnostics (read-only; gates are NEVER loosened).
POLYMARKET_BREGMAN_TOP_NEAR_MISSES=10
POLYMARKET_BREGMAN_NEAR_MISS_STORE_CAP=1000
# Cache-only/replay Grok is for OFFLINE replay + deterministic tests only. Leave
# these at the paper-training defaults below; set to 0/1 only for offline replay.
REPLAY_ALLOW_GROK_NETWORK=1
REPLAY_USE_CACHED_GROK=0

# CANONICAL xAI key — paste locally; do not commit. GROK_API_KEY is NOT required.
XAI_API_KEY=

# ---------------------------------------------------------------------------
# TradingView indicator webhook intake (OBSERVE-ONLY external candidate signal)
# ---------------------------------------------------------------------------
# TradingView alerts feed Hermes candidate signals ONLY. They can NEVER place a trade, resize a
# trade, bypass the strategy/execution gate, or override Polymarket orderbook checks — the normal
# Hermes strategy + strict execution-quality gate remain the sole trade authority.
#
# The webhook is DISABLED unless a secret is set, and binds to 127.0.0.1 by default (private to
# the host). Expose it deliberately via an SSH tunnel or an authenticated reverse proxy; never
# point TradingView at it directly without one. The shared secret must be sent either in the JSON
# body as {"secret": "..."} or in the "X-Tradingview-Secret" header.
#
# Example TradingView alert message (JSON):
#   {"secret":"<TRADINGVIEW_WEBHOOK_SECRET>","bot_name":"hermes","symbol":"BTCUSD",
#    "timeframe":"5","direction":"UP","strength":0.8,"indicator_name":"my_ind",
#    "event_id":"{{timenow}}-{{ticker}}","bar_time":"{{timenow}}"}
TRADINGVIEW_WEBHOOK_SECRET=
# INDEX:BTCUSD only (normalized to BTCUSD). Binance BTCUSDT is not accepted.
TRADINGVIEW_ALLOWED_SYMBOLS=BTCUSD,INDEX:BTCUSD
# Bot name the alert must carry: TRADINGVIEW_BOT_NAME takes precedence, else BOT_NAME, else hermes.
BOT_NAME=hermes
TRADINGVIEW_BOT_NAME=hermes
TRADINGVIEW_WEBHOOK_HOST=127.0.0.1
TRADINGVIEW_WEBHOOK_PORT=8787
TRADINGVIEW_WEBHOOK_PATH=/webhooks/tradingview
# TradingView only allows HTTP on port 80. On the VPS the public URL is:
#   http://<vps-ip>/webhooks/tradingview
# (hermes-trading-engine on :80 proxies to hermes-training:8787). Set TRADINGVIEW_WEBHOOK_SECRET
# and TRADINGVIEW_WEBHOOK_HOST=0.0.0.0 so the training container accepts docker-network forwards.
TRADINGVIEW_WEBHOOK_HOST=0.0.0.0
TRADINGVIEW_WEBHOOK_PUBLISH=127.0.0.1:8787
# Public pulse dashboard (no SSH tunnel). On VPS use port 80: PULSE_DASHBOARD_PUBLISH=0.0.0.0:80
# → open http://<vps-ip>/dashboard in a browser.
PULSE_DASHBOARD_PUBLISH=0.0.0.0:8800
# Reject alerts whose bar/alert timestamp is older than this many seconds (0 disables the check).
TRADINGVIEW_MAX_AGE_S=90
# TV chart symbol for 1m/5m/10m/15m MTF (INDEX:BTCUSD normalizes to BTCUSD).
PULSE_TV_FEATURE_SYMBOL=BTCUSD
# Use TradingView as the DIRECTIONAL INDICATION SIGNAL: when 1, a paper trade is taken only if a
# FRESH TradingView signal exists and its direction matches the trade side. Restrict-only — it can
# only PREVENT trades, never force one or bypass the execution gate.
PULSE_TRADINGVIEW_SIGNAL_GATE=0
# When signal gate is on: reject alerts below this strength (0=off). 0.72 ≈ STRONG-only (blocks WEAK).
PULSE_TV_MIN_SIGNAL_STRENGTH=0
# TradingView signal-bucket promotion diagnostics (observe-only). A bucket is flagged eligible
# only if win_rate >= MIN_WIN_RATE, EV-after-slippage > 0, clean reconciliation, and >= MIN_SAMPLES.
# Promotion to trading authority requires PULSE_TV_PROMOTION_ALLOWED=1 AND explicit wiring.
PULSE_TV_PROMOTION_ALLOWED=0
PULSE_TV_PROMOTION_MIN_SAMPLES=50
PULSE_TV_PROMOTION_MIN_WIN_RATE=0.80
# Forward-return horizon (s) for learning whether each signal predicted the next BTC move.
PULSE_TV_SIGNAL_HORIZON_S=300

# ---------------------------------------------------------------------------
# TradingView CONTEXT GATE (hard prior, restrict-only; PAPER ONLY). Blocks proven-losing entry
# contexts IMMEDIATELY (before the learned selectivity gate has enough samples): TradingView
# volume-state spikes, the noise hurst regime, and entries too far from resolution (ttc too high).
# Can only PREVENT trades — never forces/sizes/bypasses the execution gate. A small, hard-capped
# (<=5%) exploration rate lets a fraction of blocked candidates through (tagged) to keep learning.
# ---------------------------------------------------------------------------
# VPS paper profile: set PULSE_TV_CONTEXT_GATE=1 to block proven-losing + event-risk contexts.
PULSE_TV_CONTEXT_GATE=1
# comma-separated TradingView volume_state values to block (default: spike)
PULSE_TV_CONTEXT_BLOCK_VOLUME=spike
# comma-separated hurst regimes to block (default: noise)
PULSE_TV_CONTEXT_BLOCK_HURST=noise
# block entries when seconds-to-close >= this (entered too early). 0/blank disables the ttc rule.
PULSE_TV_CONTEXT_MAX_TTC_S=240
# event-risk blackout (restrict-only): TV liquidation_spike, TV event_blackout, Grok news high risk
PULSE_TV_CONTEXT_BLOCK_LIQUIDATION=1
PULSE_TV_CONTEXT_BLOCK_EVENT_BLACKOUT=1
PULSE_TV_CONTEXT_BLOCK_GROK_EVENT_RISK=1
PULSE_TV_CONTEXT_EXPLORATION_RATE=0
# DOWN-bias gate (Townhall P3): block proven-losing UP / bullish_aligned stacks
PULSE_TV_DOWN_BIAS_GATE=1
PULSE_TV_DOWN_BIAS_EXPLORE_RATE=0
PULSE_TV_DOWN_BIAS_BLOCK_UP_AGAINST_CONFIRMED_DOWN=0
# MTF gate (loop arch default): conflict veto only — 1m/5m agreement is NOT trade authority.
# Opt-in require_confirm/side_align for legacy high-selectivity profiles (not loop-arch default).
PULSE_TV_MTF_CONFLICT_GATE=1
PULSE_TV_MTF_REQUIRE_CONFIRM=0
PULSE_TV_MTF_REQUIRE_ALL_CONFIRM=0
PULSE_TV_MTF_REQUIRE_SIDE_ALIGN=0
PULSE_TV_MTF_CONFLICT_EXPLORE_RATE=0

# ---------------------------------------------------------------------------
# Late-window high-conviction entry mode (the "time-decay edge"; PAPER ONLY). When ON, a paper trade
# is taken only if the window is late (seconds-to-close <= MAX_TTC_S) AND the digital model is highly
# convicted (|P(up)-0.5|*2 >= MIN_CONVICTION). Restrict-only — it can only PREVENT trades, never
# force/size/bypass the execution gate. The edge is ALWAYS measured observe-only (cohort vs other)
# so you can grade it from live trades before enabling the gate. Default OFF.
# ---------------------------------------------------------------------------
PULSE_LATE_WINDOW_ENTRY=0
PULSE_LATE_WINDOW_MAX_TTC_S=120
PULSE_LATE_WINDOW_MIN_CONVICTION=0.40

# ---------------------------------------------------------------------------
# Grok/xAI signal-intelligence (OBSERVE-ONLY, off the hot path, fail-open). Needs XAI_API_KEY.
# A = batch analyst over the TradingView signal-learning report (research note, diagnostics only).
# B = per-signal P(up) prediction graded vs the realized BTC move (never trades; promotion-gated).
# A shared budget caps daily $ + per-feature hourly calls across A, B, and the event-risk overlay.
# Neither A nor B can place, size, or bypass a trade — the execution gate stays sole authority.
# ---------------------------------------------------------------------------
GROK_SIGNAL_ANALYST_ENABLED=1
GROK_SIGNAL_PREDICTOR_ENABLED=1
GROK_ANALYST_INTERVAL_S=1800
GROK_BUDGET_DAILY_USD=35
GROK_EST_USD_PER_CALL=0.02
GROK_PREDICTOR_MAX_CALLS_PER_HOUR=60
GROK_ANALYST_MAX_CALLS_PER_HOUR=4

# ---------------------------------------------------------------------------
# Grok DECISION ENGINE — "Grok decides, bot executes" (PAPER ONLY).
#   off    = disabled
#   shadow = Grok decides + is graded EVERY window, but the bot does NOT trade on it (safe default;
#            proves whether Grok beats the baseline before it gets authority)
#   follow = the bot follows Grok's direction/size, subject ONLY to the deterministic floor
#            (execution-quality realism, risk caps, decision freshness). Fail-CLOSED -> no_trade.
# ---------------------------------------------------------------------------
PULSE_GROK_DECIDER_MODE=shadow
PULSE_GROK_DECIDER_MODEL=grok-4.3
PULSE_GROK_DECIDER_TIMEOUT_S=18
# enable xAI live web/X news search on DEEP tier only (mispricing + 15m entry band)
PULSE_GROK_DECIDER_USE_SEARCH=1
PULSE_GROK_DECIDER_MIN_CONFIDENCE=0.55
PULSE_GROK_DECIDER_TTL_S=240
PULSE_GROK_DECIDER_MAX_CALLS_PER_HOUR=120
# Tiered compute: light=p_up only, full=v2 decision, deep=full+search
PULSE_GROK_TIERED_COMPUTE=1
PULSE_GROK_TIER_FULL_DIVERGENCE_MIN=0.025
PULSE_GROK_TIER_DEEP_DIVERGENCE_MIN=0.04
PULSE_GROK_NEWS_REFRESH_S=300
# A/B canary: fraction of windows to FOLLOW Grok (the rest run the baseline control arm). 1.0=full.
PULSE_GROK_DECIDER_FOLLOW_FRACTION=1.0
# FOLLOW circuit breakers (trip -> stop following / use baseline for the cooldown window):
PULSE_GROK_DECIDER_MAX_CONSECUTIVE_LOSSES=4
PULSE_GROK_DECIDER_DAILY_LOSS_CAP_USD=30
PULSE_GROK_DECIDER_MAX_LATENCY_S=20
PULSE_GROK_DECIDER_COOLDOWN_S=1800
# periodic web/X news digest cadence (only runs when PULSE_GROK_DECIDER_USE_SEARCH=1)
PULSE_GROK_NEWS_REFRESH_S=300

# ---------------------------------------------------------------------------
# Loop engineering: #1 independent Claude maker-checker VERIFIER + #4 research meta-loop.
# Needs an Anthropic key (set ANTHROPIC_API_KEY). The verifier can ONLY veto/shrink a Grok-proposed
# paper trade (never force one); fail-open (no key/error -> approve, logged). The research loop reads
# the full report + lessons and proposes exploit/avoid contexts + bounded knob nudges + lessons
# (observe-only unless PULSE_RESEARCH_AUTO_APPLY=1). PAPER ONLY.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
PULSE_VERIFIER_ENABLED=1
PULSE_VERIFIER_FAIL_OPEN=1
PULSE_VERIFIER_MAX_CALLS_PER_HOUR=120
PULSE_RESEARCH_LOOP_ENABLED=1
PULSE_RESEARCH_INTERVAL_S=3600
PULSE_RESEARCH_AUTO_APPLY=0
PULSE_RESEARCH_MAX_CALLS_PER_HOUR=6
CLAUDE_BUDGET_DAILY_USD=10
CLAUDE_EST_USD_PER_CALL=0.01

# ---------------------------------------------------------------------------
# OBSERVE-ONLY BTC Pulse Edge Signal: CEX basket momentum (Binance+Coinbase, optionally Kraken+
# Bitstamp) + Polymarket stale-price divergence + time-to-resolution + orderbook pressure, blended
# into a bounded pulse_edge_score. All observe-only; never trades/vetoes/resizes/bypasses the gate.
# Kraken+Bitstamp add extra REST calls so they are opt-in (off by default to protect the hot path).
# ---------------------------------------------------------------------------
HERMES_EDGE_SIGNAL_ENABLED=1
HERMES_EDGE_EXTRA_CEX_ENABLED=0
HERMES_EDGE_PROMOTION_ALLOWED=0
HERMES_EDGE_PROMOTION_MIN_SAMPLES=50
HERMES_EDGE_PROMOTION_MIN_WIN_RATE=0.80

# ---------------------------------------------------------------------------
# Learned Selectivity Gate v1 (PAPER ONLY): between the directional decision and the execution
# gate, reject candidates whose entry-time bucket has >= MIN_SAMPLES settled trades and is proven
# losing (win_rate < MIN_WIN_RATE, or PnL < 0, or asymmetric loss). Uses LIVE ledger evidence. It
# can only make the bot MORE selective — it never trades, resizes, or bypasses the execution gate.
# Exploration (<=5%) occasionally lets a rejected bucket through, tagged + tracked separately.
# ---------------------------------------------------------------------------
PULSE_SELECTIVITY_GATE_ENABLED=1
PULSE_SELECTIVITY_MIN_SAMPLES=30
PULSE_SELECTIVITY_MIN_WIN_RATE=0.52
PULSE_SELECTIVITY_EXPLORATION_RATE=0.05
PULSE_CALIB_MIN_SAMPLES=30
PULSE_CALIB_MAX_SHRINK=0.5

# ---------------------------------------------------------------------------
# Closed-loop learning (PAPER ONLY): the bot's own calibrated edge model adjusts the DIRECTIONAL
# probability used to decide trades, so it improves as it runs. Influence is EARNED (ramps with
# sample count), GATED (only when the model is calibrated), and SELF-DISABLING (drops to 0 if the
# calibration error exceeds the cap). The strict execution-quality gate, paper-realism, and ledger
# reconciliation are UNCHANGED and still veto every trade — learning can never bypass them.
# ---------------------------------------------------------------------------
PULSE_LEARNING_ENABLED=0
PULSE_DIRECTIONAL_REQUIRE_WINNING=1
PULSE_MIN_REWARD_RISK=0.35
PULSE_ARB_ENABLED=0
PULSE_ARB_MAX_USD=300

# ---------------------------------------------------------------------------
# Verifiable stop conditions (agent-independent kill switches; Loop Eng #6)
# ---------------------------------------------------------------------------
PULSE_STOP_ENABLED=1
PULSE_STOP_ROLLING_N=50
PULSE_STOP_MIN_SAMPLES=30
PULSE_STOP_MIN_PROFIT_FACTOR=0.85
PULSE_STOP_MAX_DRAWDOWN_PCT=25.0
PULSE_LEARNING_MIN_SAMPLES=60
PULSE_LEARNING_MAX_WEIGHT=0.5
PULSE_LEARNING_RAMP_SAMPLES=300
PULSE_LEARNING_MAX_CALIB_ERROR=0.15
# Market-beating veto: blend weight=0 when model Brier > market Brier after this many graded windows.
PULSE_LEARNING_BENCH_MIN_SAMPLES=20
PULSE_LEARNING_BENCH_MARGIN=0.0

# ---------------------------------------------------------------------------
# HIGH WIN RATE profile (copy block to VPS .env — fewer trades, higher selectivity)
# Loop arch: Grok → verifier → execution gate owns direction; TV is observe-only context.
# Do NOT enable PULSE_TRADINGVIEW_SIGNAL_GATE or PULSE_TV_MTF_REQUIRE_CONFIRM for trade authority.
# Evidence: DOWN_STRONG 77% WR, TV-aligned 89% WR, ttc 120–240s bucket 89% WR.
# Pair with Pine: Send weak signals OFF, Strong min score 9, Score gap 3 (both 1m+5m charts).
# ---------------------------------------------------------------------------
# PULSE_TV_CONTEXT_MAX_TTC_S=120
# PULSE_LATE_WINDOW_MAX_TTC_S=120
# PULSE_LATE_WINDOW_MIN_CONVICTION=0.45
# PULSE_MIN_REWARD_RISK=0.40
# PULSE_SELECTIVITY_MIN_WIN_RATE=0.58
# PULSE_SELECTIVITY_EXPLORATION_RATE=0
# PULSE_DIRECTIONAL_EXPLORE_RATE=0
# PULSE_CEX_LEAD_TV_STRENGTH_THR=0.72

# ---------------------------------------------------------------------------
# Inspection / validation artifacts
# ---------------------------------------------------------------------------
INSPECTION_INCLUDE_TRAINING_ARTIFACTS=1
POLYMARKET_INSPECTION_SUMMARY_ENABLED=1
POLYMARKET_CLOSED_LOOP_REPORT_ENABLED=1
POLYMARKET_RUNTIME_VALIDATION_ENABLED=1

# Expected required artifacts:
# metrics/inspection_summary.json
# metrics/closed_loop_learning.json
# metrics/learning_feedback.json
# metrics/active_learning.json
# metrics/paper_realism.json
# metrics/bregman_execution.json
# metrics/strategy_priority.json
# metrics/profitability_ranking.json
