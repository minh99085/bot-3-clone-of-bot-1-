# Hermes v2 Paper — environment template
# Copy to .env before docker compose up

# ── Paper lock (do not change for this deployment) ──────────────────────────
HERMES_PAPER_ONLY=1
HERMES_LIVE=0

# ── Bankroll & cadence (per-instance capital is set in docker-compose) ───────
HERMES_CAPITAL=2000
HERMES_INTERVAL=300

# Public HTTP port for nginx (dashboard at http://<IP>/dashboard)
HERMES_HTTP_PORT=80

# Logging (overridden per instance in docker-compose)
HERMES_LOG_DIR=/app/logs
HERMES_LOG_LEVEL=INFO
HERMES_HEARTBEAT_MAX_AGE=900

# Optional: force synthetic markets when Polymarket Gamma is unreachable
HERMES_FORCE_SYNTHETIC=0

# ── Market filters (see config/market_filters.yaml) ─────────────────────────
# Per-container MARKET_FILTER is set in docker-compose.yml:
#   btc5 | btc15 | eth5 | sol5 | rotator
# Leave unset here — compose injects the right value per service.
HERMES_SCOPE_BTC_UPDOWN_ONLY=1

# PURE mode (B1) — set per lane by docker-compose, not here. When "1":
# fixed sizing (HERMES_PURE_SIZE_PCT, default 0.02) and the adaptive stack
# (bandit, lessons, risk pauses, MCHB/RGMC/CBPF) is disabled so lanes differ
# only in q. lane02_autonomy runs with it OFF as the autonomy A/B twin.
# HERMES_PURE_MODE=0
# HERMES_PURE_SIZE_PCT=0.02

# Settlement uses Polymarket's actual resolution + CEX (free on-chain
# AggregatorV3 is a last-resort price fallback). A 15m window needs no paid
# Chainlink stream, so crypto does NOT hard-fail without one.
# Optional: force the paid Data Streams tier (operator override) —
#   HERMES_REQUIRE_ORACLE=1  plus:
# CHAINLINK_API_KEY=
# CHAINLINK_API_SECRET=
# CHAINLINK_RPC_URL=https://ethereum.publicnode.com

# Polymarket read-only (paper never needs a private key)
# POLYMARKET_CLOB_HOST=https://clob.polymarket.com
# POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
